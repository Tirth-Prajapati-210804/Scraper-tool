# ─── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flight_harvester
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
ADMIN_EMAIL=admin@flightharvester.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_FULL_NAME=System Admin

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# ─── Scheduler ───────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# ─── Flight Data Providers ────────────────────────────────────────────────────
# Leave ALL provider keys EMPTY until you are ready to activate a paid tier.
# The app runs fully without them — health check reports each as "disabled".
# Activate one provider at a time as you move through phases.

# Phase 2+ — Kiwi Tequila (https://tequila.kiwi.com)
KIWI_API_KEY=

# Phase 2+ — FlightAPI.io (https://flightapi.io)
FLIGHTAPI_API_KEY=

# Phase 2+ — Serper.dev Google Search (https://serper.dev)
SERPER_API_KEY=

# ─── Monitoring (optional) ───────────────────────────────────────────────────
# Leave empty until Phase 6+ (monitoring phase)
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
