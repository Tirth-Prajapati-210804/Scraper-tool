# ─── Database ────────────────────────────────────────────────────────────────
# For local dev (outside Docker): use localhost
# For Docker: docker-compose overrides this automatically — you don't need to change it
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flight_data_scrapper

# ─── Auth (Required) ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
ADMIN_EMAIL=admin@flightdatascrapper.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_FULL_NAME=System Admin

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=true
# For Docker: docker-compose overrides this automatically — you don't need to change it
CORS_ORIGINS=["http://localhost:5173"]

# ─── Scheduler ───────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# ─── Flight Data Providers ────────────────────────────────────────────────────
# Leave a key empty to disable that provider.

# Travelpayouts / Aviasales (PRIMARY — FREE forever)
# Get your token: travelpayouts.com → Partners → Profile → API token
TRAVELPAYOUTS_TOKEN=

# SerpAPI Google Flights (SECONDARY — real-time accurate prices)
# Get your key: serpapi.com → Dashboard
SERPAPI_KEY=

# ─── Monitoring (optional) ───────────────────────────────────────────────────
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
