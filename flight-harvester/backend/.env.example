# ─── Database ────────────────────────────────────────────────────────────────
# For local dev (outside Docker): use localhost
# For Docker: docker-compose overrides this automatically — you don't need to change it
DATABASE_URL=postgresql://neondb_owner:npg_ap4mRPn5vYlV@ep-sweet-mode-a1q9gg67-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─── Auth (Required) ─────────────────────────────────────────────────────────
# Generate a real secret: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE-WITH-OUTPUT-OF-openssl-rand-hex-32
ADMIN_EMAIL=admin@vivavistavaactions.com
# Must be at least 12 characters. Cannot contain "change-me".
ADMIN_PASSWORD=Admin@123456
ADMIN_FULL_NAME=System Admin

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
# For local dev: http://localhost:5173
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173

# ─── Scheduler ───────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# ─── Flight Data Providers ────────────────────────────────────────────────────
# SerpAPI Google Flights — real-time accurate prices
# Get your key: serpapi.com → Dashboard
SERPAPI_KEY=

# Speed vs accuracy tradeoff:
#   true  = mirrors exact Google Flights UI prices (~20s/search, recommended for production)
#   false = faster estimates (~5s/search, ~5-10% variance, good for demos or large datasets)
SERPAPI_DEEP_SEARCH=true

# Demo mode — generates realistic fake prices without any API key.
# Set to true for demos/presentations. Remove or set to false in production.
DEMO_MODE=false

# ─── Scraping tuning ─────────────────────────────────────────────────────────
# SCRAPE_BATCH_SIZE=10       # parallel searches per batch (default: 10)
# SCRAPE_DELAY_SECONDS=1.0   # delay between batches in seconds (default: 1.0)

# ─── Monitoring (optional) ───────────────────────────────────────────────────
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
