# ─── Required ────────────────────────────────────────────────────────────────

# ── Local PostgreSQL (default for development) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flight_harvester

# ── Supabase (recommended for production) ────────────────────────────────────
# Use the "Transaction pooler" URL from Supabase → Project Settings → Database
# Format: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# DATABASE_URL=postgresql+asyncpg://postgres.abcdefghij:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
ADMIN_EMAIL=admin@flightharvester.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_FULL_NAME=System Admin

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

# ─── Scheduler ───────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# ─── Flight Data Providers ────────────────────────────────────────────────────
# The system tries providers in order: Travelpayouts → SerpAPI → Mock
# Leave a key empty to disable that provider.

# ── Travelpayouts / Aviasales (PRIMARY — FREE forever) ───────────────────────
# Calendar API: one request returns cheapest prices for every day in a month.
# Perfect for bulk date scanning across hundreds of routes.
#
# How to get your token:
#   1. Go to https://www.travelpayouts.com/ and create a free account
#   2. In the dashboard, go to the "Partners" section
#   3. Your API token is shown in your Profile → API token
#
# Test it: curl "https://api.travelpayouts.com/v1/prices/calendar?origin=AMD&destination=DEL&depart_date=2026-05&currency=usd" -H "X-Access-Token: YOUR_TOKEN"
TRAVELPAYOUTS_TOKEN=

# ── SerpAPI Google Flights (SECONDARY — real-time accurate prices) ────────────
# Returns exact prices from google.com/flights — same as what you see in browser.
# Uses deep_search=true for 100% price accuracy.
#
# How to get your key:
#   1. Go to https://serpapi.com/ and create a free account (no credit card)
#   2. Copy the API key from your dashboard
#
# Free plan: ~100 searches/month (enough for development and small-scale use)
# Paid plans: $75/month for 5,000 searches
SERPAPI_KEY=

# ─── Mock provider (local testing only) ──────────────────────────────────────
# Set to any non-empty string to generate fake flight data without API keys.
# Lets you verify the full pipeline (collect → DB → Excel → dashboard).
# Leave EMPTY in production.
MOCK_PROVIDER_KEY=

# ─── Monitoring (optional) ───────────────────────────────────────────────────
# Leave empty until Phase 6+ (monitoring phase)
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
